# ═══════════════════════════════════════════════════════════════
#  Subscription Manager Panel — переменные окружения
#  Скопируйте: cp panel/.env.example panel/.env
#  Заполните все значения без кавычек
# ═══════════════════════════════════════════════════════════════

# ── API Security ──────────────────────────────────────────────
# Сгенерируйте: python -c "import secrets; print(secrets.token_hex(32))"
PANEL_API_KEY=

# ── Xray gRPC ─────────────────────────────────────────────────
XRAY_GRPC_HOST=127.0.0.1:10085

# ── Сервер ────────────────────────────────────────────────────
SERVER_IP=37.1.212.51

# ── Порты протоколов ──────────────────────────────────────────
PORT_VLESS_REALITY=443
PORT_VLESS_XHTTP=8443
PORT_VLESS_GRPC=2053
PORT_VLESS_WS=2083
PORT_HYSTERIA2=10443
PORT_SHADOWSOCKS=2085

# ── Reality Keys (получить из xray keygen) ───────────────────
REALITY_PUBLIC_KEY=
REALITY_SHORT_ID=
REALITY_SNI=www.microsoft.com

# ── Hysteria2 ─────────────────────────────────────────────────
HYSTERIA2_PASSWORD=
HYSTERIA2_OBFS_PASSWORD=
HYSTERIA2_SNI=www.microsoft.com

# ── Shadowsocks 2022 ──────────────────────────────────────────
SHADOWSOCKS_METHOD=2022-blake3-aes-256-gcm
SHADOWSOCKS_PASSWORD=

# ── IP Limit ──────────────────────────────────────────────────
DEFAULT_IP_LIMIT=2
IP_CHECK_INTERVAL=30

# ── Feature Toggles ───────────────────────────────────────────
ENABLE_TRAFFIC_LIMITS=True
ENABLE_IP_LIMITS=True

# ── Relay RU (опционально) ────────────────────────────────────
RELAY_ENABLED=False
RELAY_IP=
RELAY_PORT=443
RELAY_UUID=
RELAY_PUBLIC_KEY=
RELAY_SHORT_ID=
RELAY_SNI=

# ── Пути к БД ─────────────────────────────────────────────────
PANEL_DB_PATH=panel/data/panel.db
BOT_DB_PATH=bot/data/bot.db
