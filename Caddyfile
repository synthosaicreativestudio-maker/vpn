{
    auto_https disable_redirects
}

# HTTPS на порту 8086 — оставляем как fallback для старых ссылок
38.180.81.181.sslip.io:8086, 185.4.67.223.nip.io:8086, sub.synthosai.ru:8086 {
    reverse_proxy 127.0.0.1:8085
}

# HTTP на порту 80 — основной путь подписки (порт 80 не блокируется DPI)
# Relay:80 → dokodemo → US:80 → Caddy → Panel
:80 {
    handle /tg-bot/* {
        uri strip_prefix /tg-bot
        reverse_proxy https://api.telegram.org {
            header_up Host api.telegram.org
        }
    }
    handle /sub/* {
        reverse_proxy 127.0.0.1:8085
    }
    handle /routing/* {
        reverse_proxy 127.0.0.1:8085
    }
    handle /health {
        reverse_proxy 127.0.0.1:8085
    }
    handle {
        respond "OK" 200
    }
}
